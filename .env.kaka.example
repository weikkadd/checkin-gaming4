# ============================================================
# 卡卡项目自动续期 — 环境变量配置
# ============================================================
# 复制此文件为 .env 并填写实际值
#   cp .env.kaka.example .env.local
# ============================================================

# Google 账号（用于 OAuth 登录 dash.aclclouds.com）
KAKA_GOOGLE_EMAIL=your-google-email@gmail.com
KAKA_GOOGLE_PASSWORD=your-google-password

# Gotify 通知（可选，用于续期成功/失败推送）
GOTIFY_SERVER_URL=
GOTIFY_TOKEN=
